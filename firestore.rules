rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Team Assessments collections
    match /sessions/{document=**} {
      allow read, write: if true;
    }
    match /responses/{document=**} {
      allow read, write: if true;
    }
    // AI Maturity Assessment collections
    match /maturity_sessions/{document=**} {
      allow read, write: if true;
    }
    match /maturity_responses/{document=**} {
      allow read, write: if true;
    }
    // AI Maturity Assessment (English) collections
    match /maturity_sessions_en/{document=**} {
      allow read, write: if true;
    }
    match /maturity_responses_en/{document=**} {
      allow read, write: if true;
    }
  }
}
